# Google Generative AI (Gemini) — used by the mangle route
GOOGLE_API_KEY=

# Gradium TTS
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=

# Last.fm — cron corpus refresh
LASTFM_API_KEY=

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=

# Supabase (leaderboard / persistence)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Hook-lines encryption secret — REQUIRED in production.
# Generate with: openssl rand -base64 32
# Must be the same across all Vercel function instances (set in Vercel dashboard).
HOOK_LINES_SECRET=

# Set to "true" to skip Gemini and return mock mangled lyrics (useful in CI/staging)
MOCK_MANGLE=false
